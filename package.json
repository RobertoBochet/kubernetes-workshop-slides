{
  "name": "kubernetes-workshop-slides",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "slidev build",
    "dev": "slidev --open",
    "export": "slidev export",
    "prepare": "simple-git-hooks",
    "lint": "prettier . --check",
    "lint:fix": "prettier . --write"
  },
  "dependencies": {
    "@iconify-json/devicon": "^1.2.62",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/vscode-icons": "^1.2.49",
    "@iconify/vue": "^5.0.1",
    "@slidev/cli": "~52.14.2",
    "@slidev/theme-default": "latest",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "lint-staged": "^17.0.4",
    "playwright-chromium": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-slidev": "^1.0.5",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint-staged"
  },
  "lint-staged": {
    "**/*.{md,yaml,yml,ts,vue,css}": [
      "prettier --write"
    ]
  }
}
